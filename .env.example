# GitHub API token (optional — increases rate limit from 60 to 5000 req/h)
# Generate at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=

# Public GitHub username for live stats
NEXT_PUBLIC_GITHUB_USERNAME=yocopk

# Public contact email shown on the site
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com
